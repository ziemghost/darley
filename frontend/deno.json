{
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "check": "deno check src/**/*.ts src/**/*.tsx"
  },
  "imports": {
    "react": "npm:react@^19.2.0",
    "react-dom": "npm:react-dom@^19.2.0",
    "react-dom/client": "npm:react-dom@^19.2.0/client",
    "react/jsx-runtime": "npm:react@^19.2.0/jsx-runtime",
    "@types/react": "npm:@types/react@^19.2.0",
    "lightweight-charts": "npm:lightweight-charts@^5.2.0",
    "vite": "npm:vite@^8.0.0",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^6.0.0"
  },
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "unstable": ["sloppy-imports"],
  "nodeModulesDir": "auto"
}
